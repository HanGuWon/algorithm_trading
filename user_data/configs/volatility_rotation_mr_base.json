{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "liquidation_buffer": 0.08,
  "strategy": "VolatilityRotationMR",
  "timeframe": "5m",
  "max_open_trades": 6,
  "stake_currency": "USDT",
  "stake_amount": 200,
  "tradable_balance_ratio": 0.99,
  "amend_last_stake_amount": true,
  "last_stake_amount_min_ratio": 0.5,
  "amount_reserve_percent": 0.05,
  "fiat_display_currency": "USD",
  "cancel_open_orders_on_exit": true,
  "dataformat_ohlcv": "feather",
  "dataformat_trades": "feather",
  "db_url": "sqlite:///user_data/tradesv3_volatility_rotation_mr.sqlite",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1
  },
  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "emergency_exit": "market",
    "force_entry": "market",
    "force_exit": "market",
    "stoploss": "market",
    "stoploss_on_exchange": false
  },
  "order_time_in_force": {
    "entry": "GTC",
    "exit": "GTC"
  },
  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "password": "",
    "ccxt_config": {},
    "ccxt_async_config": {},
    "pair_whitelist": [],
    "pair_blacklist": [
      ".*UP/USDT:USDT",
      ".*DOWN/USDT:USDT",
      ".*BULL/USDT:USDT",
      ".*BEAR/USDT:USDT"
    ]
  },
  "pairlists": [
    {
      "method": "VolumePairList",
      "number_assets": 25,
      "sort_key": "quoteVolume",
      "refresh_period": 1800
    },
    {
      "method": "AgeFilter",
      "min_days_listed": 30
    },
    {
      "method": "SpreadFilter",
      "max_spread_ratio": 0.0028,
      "refresh_period": 1800
    },
    {
      "method": "RangeStabilityFilter",
      "lookback_days": 5,
      "min_rate_of_change": 0.08,
      "max_rate_of_change": 0.8,
      "refresh_period": 43200
    },
    {
      "method": "VolatilityFilter",
      "lookback_days": 5,
      "min_volatility": 0.04,
      "max_volatility": 0.35,
      "refresh_period": 43200
    }
  ],
  "internals": {
    "process_throttle_secs": 5
  },
  "api_server": {
    "enabled": false
  }
}
