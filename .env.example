FREQTRADE_IMAGE=freqtradeorg/freqtrade:2026.2
TZ=UTC

# Keep these blank for public commits. Fill them only on the cloud host.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Dry-run is the default deployment mode. Do not point this at a research-only
# strategy unless it has passed docs/validation/strict_validation_gate.md.
FREQTRADE_STRATEGY=VolatilityRotationMR

# Live startup remains blocked unless all three are set on the host after a
# promoted strict-validation report and a stable dry-run soak.
ALLOW_LIVE_TRADING=
DRYRUN_STARTED_AT=
LIVE_DRYRUN_MIN_DAYS=14
STRICT_VALIDATION_REPORT=docs/validation/strict_validation_gate.md
